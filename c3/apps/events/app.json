{
  "name": "events",
  "description": "Plan events and trips — availability polls, itineraries, reminders, task assignment",
  "trust_level": "builtin",
  "access": {
    "commands": {},
    "dm": ["hosts"],
    "group": ["session_participants"]
  },
  "memory_schema": {
    "event": { "fields": ["title", "type", "date", "location", "attendees", "budget", "tasks", "status"] },
    "trip": { "fields": ["destination", "dates", "budget", "itinerary", "packing", "status"] }
  }
}
